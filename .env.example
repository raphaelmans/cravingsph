DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SECRET_KEY=YOUR_SERVICE_ROLE_KEY

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_ANON_KEY

# Required in production for OAuth callbacks, metadata, and canonical URLs.
NEXT_PUBLIC_APP_URL=http://localhost:3443

# Optional — logging configuration (defaults: level=info in prod/debug in dev, service=api)
# LOG_LEVEL=info
# SERVICE_NAME=api

# Feature flags — set to "true" to enable (default: disabled)
# FF_BRANCH_OPS_PORTAL=true
# FF_BRANCH_SCOPED_STAFF_ACCESS=true
# FF_BRANCH_PORTAL_SHORT_ROUTES=true
# FF_OWNER_CONSOLE_SIDEBAR_V2=true
# FF_OWNER_TEAM_ACCESS=true
# FF_OWNER_WORKSPACE_SWITCHER=true
